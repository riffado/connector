{
    "name": "openplaud-connector",
    "version": "0.1.3",
    "description": "Browser extension that bridges your Plaud session to OpenPlaud (self-hosted or hosted).",
    "private": true,
    "license": "AGPL-3.0",
    "repository": {
        "type": "git",
        "url": "https://github.com/openplaud/connector.git"
    },
    "homepage": "https://github.com/openplaud/connector#readme",
    "scripts": {
        "dev": "vite",
        "build": "tsc --noEmit && vite build",
        "type-check": "tsc --noEmit",
        "zip": "mkdir -p dist-zip && cd dist && zip -r ../dist-zip/openplaud-connector-$npm_package_version.zip . && cd ..",
        "release": "pnpm build && pnpm zip"
    },
    "devDependencies": {
        "@crxjs/vite-plugin": "^2.2.0",
        "@types/chrome": "^0.0.287",
        "typescript": "^5.7.2",
        "vite": "^6.0.7"
    }
}
